#!name=JD_fruit_Task
#!desc=京东薅羊毛
#!system=ios

# Surge软件Task配置 By lxk0301
# GitHub主页(https://github.com/lxk0301/scripts)
# TG讨论组 (https://t.me/JD_fruit_pet)
# TG通知频道 (https://t.me/jdfruit)
# Surge的Task模块订阅链接: (https://raw.githubusercontent.com/52znn/Surge/master/Module/JD_fruit_Task.sgmodule)

[Script]
# > 京东农场
京东农场 = type=cron,cronexp=5 6-18/6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_fruit.js,script-update-interval=0

# > 京东萌宠
京东萌宠 = type=cron,cronexp=20 7-19/6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_pet.js,script-update-interval=0

# > 京东种豆得豆
京东种豆得豆 = type=cron,cronexp=10 7-21/2 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_plantBean.js,script-update-interval=0

# > 宠汪汪(主要是日常任务,不过里面也有喂食和领取三餐狗粮)
宠汪汪 = type=cron,cronexp=15 */2 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_joy.js,script-update-interval=0

# > 宠汪汪喂食
宠汪汪喂食 = type=cron,cronexp=12 */1 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_joy_feedPets.js,script-update-interval=0

# > 宠汪汪偷好友积分与狗粮
宠汪汪偷好友积分与狗粮 = type=cron,cronexp=0 0,6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_joy_steal.js,script-update-interval=0

# > 宠汪汪积分兑换奖品
宠汪汪积分兑换奖品 = type=cron,cronexp=1 0,8,12,16 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_joy_reward.js,script-update-interval=0

# > 京东天天加速
京东天天加速 = type=cron,cronexp=8 */3 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_speed.js,script-update-interval=0

# > 京东摇钱树
京东摇钱树 = type=cron,cronexp=15 */5 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_moneyTree.js,script-update-interval=0

# > 京小超
京小超 = type=cron,cronexp=11 1-23/5 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_superMarket.js,script-update-interval=0

# > 京小超领蓝币(兑换京豆)
京小超领蓝币(兑换京豆) = type=cron,cronexp=0 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_blueCoin.js,script-update-interval=0

# > 取关京东店铺商品
取关京东店铺商品 = type=cron,cronexp=55 23 * * *,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_unsubscribe.js,script-update-interval=0

# > 进店领豆
进店领豆 = type=cron,cronexp=45 10 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_shop.js,script-update-interval=0

# > 摇京豆
摇京豆 = type=cron,cronexp=5 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_club_lottery.js,script-update-interval=0

# > 京东手机狂欢城
京东手机狂欢城 = type=cron,cronexp=1 0-18/6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_818.js,script-update-interval=0

# > 京东全民开红包
京东全民开红包 = type=cron,cronexp=1 1 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_redPacket.js,script-update-interval=0

# > 京东星推官
京东星推官 = type=cron,cronexp=0 0 * * * *,wake-system=1,timeout=600,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_xtg.js,script-update-interval=0

# > 宠汪汪邀请助力与赛跑助力
宠汪汪邀请助力与赛跑助力 = type=cron,cronexp=15 10 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_joy_run.js,script-update-interval=0

# > 京豆变动通知
京豆变动通知 = type=cron,cronexp=2 9 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_bean_change.js,script-update-interval=0

# > 京东全民营业领金币
京东全民营业领金币 = type=cron,cronexp=20 * * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/scripts/raw/master/jd_collectProduceScore.js,script-update-interval=0
