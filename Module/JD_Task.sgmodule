#!name=JD_Task
#!desc=京东薅羊毛
#!system=ios

# Surge软件Task配置 By lxk0301
# GitHub主页(https://github.com/lxk0301/)
# TG讨论组 (https://t.me/JD_fruit_pet)
# TG通知频道 (https://t.me/jdfruit)
# Surge的Task模块订阅链接: (https://raw.githubusercontent.com/52znn/Surge/master/Module/JD_Task.sgmodule)

[MITM]
hostname = %APPEND% api.m.jd.com, draw.jdfcloud.com, jdjoy.jd.com, account.huami.com

[Script]
# > 京豆变动通知
京豆变动通知 = type=cron,cronexp=2 9 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_bean_change.js,script-update-interval=0

# > 小米运动
#小米运动 = type=cron,cronexp=25 17 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/backUp/xmSports.js,script-update-interval=0

# > 小米运动获取Token
#小米运动获取Token = type=http-response,pattern=^https:\/\/account\.huami\.com\/v2\/client\/login,requires-body=1,max-size=0,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/backUp/xmSports.js,script-update-interval=0

# > 宠汪汪邀请助力与赛跑助力
宠汪汪邀请助力与赛跑助力 = type=cron,cronexp=15 10 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_run.js,script-update-interval=0

# > 宠汪汪助力更新Token
宠汪汪助力更新Token = type=http-response,pattern=^https:\/\/draw\.jdfcloud\.com(\/mirror)?\/\/api\/user\/addUser\?code=,requires-body=1,max-size=0,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_run.js,script-update-interval=0

# > 宠汪汪助力获取Token
宠汪汪助力获取Token = type=http-response,pattern=^https:\/\/draw\.jdfcloud\.com(\/mirror)?\/\/api\/user\/user\/detail\?openId=,requires-body=1,max-size=0,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_run.js,script-update-interval=0

# > 宠汪汪强制为别人助力
宠汪汪强制为别人助力 = type=http-request,pattern=^https:\/\/draw\.jdfcloud\.com(\/mirror)?\/\/pet\/enterRoom\/h5\?reqSource=weapp&invitePin=.*+(&inviteSource=task_invite&shareSource=\w+&inviteTimeStamp=\d+&openId=\w+)?|^https:\/\/draw\.jdfcloud\.com(\/mirror)?\/\/pet\/helpFriend\?friendPin,requires-body=1,max-size=0,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_help.js,script-update-interval=0

# > 聚宝盆投狗粮辅助(github@Zero-S1搬的)
聚宝盆投狗粮辅助(github@Zero-S1搬的) = type=http-response,pattern=^https:\/\/jdjoy\.jd\.com\/pet\/getPetTreasureBox|^https:\/\/draw\.jdfcloud\.com(\/mirror)?\/\/pet\/getPetTreasureBox,requires-body=1,max-size=0,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_petTreasureBox.js,script-update-interval=0

# > 东东农场
东东农场 = type=cron,cronexp=5 6-18/6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_fruit.js,script-update-interval=0

# > 东东萌宠
东东萌宠 = type=cron,cronexp=20 7-19/6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_pet.js,script-update-interval=0

# > 京东种豆得豆
京东种豆得豆 = type=cron,cronexp=10 7-21/2 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_plantBean.js,script-update-interval=0

# > 宠汪汪(主要是日常任务,不过里面也有喂食和领取三餐狗粮)
宠汪汪 = type=cron,cronexp=15 1,7,9,12,18,21 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy.js,script-update-interval=0

# > 宠汪汪喂食
宠汪汪喂食 = type=cron,cronexp=12 */1 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_feedPets.js,script-update-interval=0

# > 宠汪汪偷好友积分与狗粮
宠汪汪偷好友积分与狗粮 = type=cron,cronexp=0 0,6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_steal.js,script-update-interval=0

# > 宠汪汪积分兑换奖品
宠汪汪积分兑换奖品 = type=cron,cronexp=1 0,8,12,16 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_joy_reward.js,script-update-interval=0

# > 京东天天加速
京东天天加速 = type=cron,cronexp=8 */3 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_speed.js,script-update-interval=0

# > 京东摇钱树
京东摇钱树 = type=cron,cronexp=15 */5 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_moneyTree.js,script-update-interval=0

# > 京小超
京小超 = type=cron,cronexp=11 1-23/5 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_superMarket.js,script-update-interval=0

# > 京小超兑换奖品
京小超兑换奖品 = type=cron,cronexp=0,30 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_blueCoin.js,script-update-interval=0

# > 取关京东店铺商品
取关京东店铺商品 = type=cron,cronexp=55 23 * * *,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_unsubscribe.js,script-update-interval=0

# > 进店领豆
进店领豆 = type=cron,cronexp=10 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_shop.js,script-update-interval=0

# > 摇京豆
摇京豆 = type=cron,cronexp=5 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_club_lottery.js,script-update-interval=0

# > 京东全民开红包
京东全民开红包 = type=cron,cronexp=1 1 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_redPacket.js,script-update-interval=0

# > 点点券
点点券 = type=cron,cronexp=20 0,20 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_necklace.js,script-update-interval=0

# > 十元街
十元街 = type=cron,cronexp=0 7 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_syj.js,script-update-interval=0

# > 东东小窝
东东小窝 = type=cron,cronexp=13 7 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_small_home.js,script-update-interval=0

# > 京喜工厂
京喜工厂 = type=cron,cronexp=10 * * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_dreamFactory.js,script-update-interval=0

# > 东东工厂
东东工厂 = type=cron,cronexp=10 * * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_jdfactory.js,script-update-interval=0

# > 京东快递
京东快递 = type=cron,cronexp=10 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_kd.js,script-update-interval=0

# > 京东汽车
京东汽车 = type=cron,cronexp=0 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_car.js,script-update-interval=0

# > 领京豆额外奖励
领京豆额外奖励 = type=cron,cronexp=10 6 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_bean_home.js,script-update-interval=0

# > 京东赚赚
京东赚赚 = type=cron,cronexp=14 11 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_jdzz.js,script-update-interval=0

# > 京东直播
京东直播 = type=cron,cronexp=10-20/5 12 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_live.js,script-update-interval=0

# > crazyJoy任务
crazyJoy任务 = type=cron,cronexp=30 8 * * *,wake-system=1,timeout=20,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_crazy_joy.js,script-update-interval=0

# > 注销京东店铺会员卡
注销京东店铺会员卡 = type=cron,cronexp=44 12 * * 6,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_unbind.js,script-update-interval=0

# > 京东汽车兑换
京东汽车兑换 = type=cron,cronexp=0 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_car_exchange.js,script-update-interval=0

# > 口袋书店
口袋书店 = type=cron,cronexp=0 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_bookshop.js,script-update-interval=0

# > 京喜签到
京喜签到 = type=cron,cronexp=5 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jx_sign.js,script-update-interval=0

# > 签到领现金
签到领现金 = type=cron,cronexp=2 0 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_cash.js,script-update-interval=0

# > 京东年货节
京东年货节 = type=cron,cronexp=1 7 * * *,wake-system=1,timeout=300,script-path=https://gitee.com/lxk0301/jd_scripts/raw/master/jd_nh.js,script-update-interval=0

# > 京东炸年兽🧨
京东炸年兽🧨 = type=cron,cronexp=0 8 * * *,wake-system=1,timeout=200,script-path=https://raw.githubusercontent.com/LXK9301/jd_scripts/master/jd_nian.js,script-update-interval=0
