#!name=JD_Task
#!desc=京东薅羊毛
#!system=ios

# Surge软件Task配置 By lxk0301
# GitHub主页(https://github.com/lxk0301/)
# TG讨论组 (https://t.me/JD_fruit_pet)
# TG通知频道 (https://t.me/jdfruit)
# Surge的Task模块订阅链接: (https://raw.githubusercontent.com/52znn/Surge/master/Module/JD_Task.sgmodule)

[MITM]
hostname = %APPEND% api.m.jd.com, draw.jdfcloud.com, jdjoy.jd.com, account.huami.com

[Script]
# > 京豆变动通知
京豆变动通知 = type=cron,cronexp=2 9 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_bean_change.js,script-update-interval=0

# > 宠汪汪邀请助力与赛跑助力
宠汪汪邀请助力与赛跑助力 = type=cron,cronexp=2 9 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_bean_change.js,script-update-interval=0

# > 宠汪汪助力更新Token
宠汪汪助力更新Token = type=cron,cronexp=2 9 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_bean_change.js,script-update-interval=0

# > 宠汪汪助力获取Token
小米运动获取Token = type=http-response,pattern=^https:\/\/account\.huami\.com\/v2\/client\/login,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/backUp/xmSports.js,script-update-interval=0

# > 宠汪汪强制为别人助力
小米运动获取Token = type=http-response,pattern=^https:\/\/account\.huami\.com\/v2\/client\/login,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/backUp/xmSports.js,script-update-interval=0

# > 聚宝盆投狗粮辅助(github@Zero-S1搬的)
小米运动获取Token = type=http-response,pattern=^https:\/\/account\.huami\.com\/v2\/client\/login,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/backUp/xmSports.js,script-update-interval=0

# > 小米运动
#小米运动 = type=cron,cronexp=25 17 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/backUp/xmSports.js,script-update-interval=0

# > 小米运动获取Token
#小米运动获取Token = type=http-response,pattern=^https:\/\/account\.huami\.com\/v2\/client\/login,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/backUp/xmSports.js,script-update-interval=0

# > 东东农场
东东农场 = type=cron,cronexp=5 6-18/6 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_fruit.js,script-update-interval=0

# > 东东萌宠
东东萌宠 = type=cron,cronexp=10 7-19/6 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_pet.js,script-update-interval=0

# > 京东种豆得豆
京东种豆得豆 = type=cron,cronexp=1 7-21/2 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_plantBean.js,script-update-interval=0

# > 宠汪汪(主要是日常任务,不过里面也有喂食和领取三餐狗粮)
宠汪汪 = type=cron,cronexp=15 1,7,9,12,18,21 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_joy.js,script-update-interval=0

# > 宠汪汪喂食
宠汪汪喂食 = type=cron,cronexp=12 */1 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_joy_feedPets.js,script-update-interval=0

# > 宠汪汪偷好友积分与狗粮
宠汪汪偷好友积分与狗粮 = type=cron,cronexp=0 0,6 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_joy_steal.js,script-update-interval=0

# > 宠汪汪积分兑换奖品
宠汪汪积分兑换奖品 = type=cron,cronexp=0 0,8,12,16 * * *,wake-system=1,timeout=300,script-path=https://raw.githubusercontent.com/lxk0301/jd_scripts/master/jd_joy_reward.js,script-update-interval=0

